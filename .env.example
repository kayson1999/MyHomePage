# 前端环境变量（Vite 要求以 VITE_ 开头）

# 冲动是魔鬼（AI 决策助手）服务地址
VITE_DECISIONER_URL=http://localhost:3001

# 打工人打卡（独立应用）服务地址
VITE_WORKER_URL=http://localhost:3002

# 用户中心服务地址
VITE_USER_CENTER_URL=http://localhost:4000

# 本站在用户中心注册的应用标识（租户 App ID）
VITE_APP_ID=your_app_id

# 管理员密钥（用于知识库文档/笔记管理权限控制）
VITE_ADMIN_TOKEN=your_admin_secret

# 知识库 API 服务端口（默认 3100）
API_PORT=3100

# 前端开发服务器端口（默认 3000）
VITE_PORT=3000

# ==================== GitHub 数据源配置 ====================
# 配置后，网站会自动从 GitHub 仓库读取项目/知识库/博客等数据
# 未配置时降级到本地 public/data/ 目录（保持原有行为）

# GitHub 仓库拥有者（你的 GitHub 用户名）
VITE_GITHUB_OWNER=your_github_username

# GitHub 仓库名称（存放数据文件的仓库）
VITE_GITHUB_REPO=your_repo_name

# GitHub 分支名（默认 main）
VITE_GITHUB_BRANCH=main

# 数据文件在仓库中的根目录（默认 data）
VITE_GITHUB_DATA_ROOT=data

# ===== 以下为 Vercel 服务端环境变量（不以 VITE_ 开头，不会暴露给前端） =====

# GitHub Personal Access Token（私有仓库必须，公开仓库可选但建议配置）
# 生成方式：GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# 权限：只需 Contents: Read-only
GITHUB_TOKEN=ghp_your_github_token

# 服务端也需要仓库信息（Serverless Function 读取）
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name
GITHUB_BRANCH=main
